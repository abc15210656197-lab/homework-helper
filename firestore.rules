rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: textbooks, materials
    // Fields:
    //   - name: string (required)
    //   - url: string (required)
    //   - fileId: string (optional)
    //   - createdAt: timestamp (required)
    //   - groupId: string (optional)
    //
    // Collection: textbook_groups, material_groups
    // Fields:
    //   - name: string (required)
    //   - createdAt: timestamp (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'abc15210656197@gmail.com';
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= min &&
             request.resource.data[field].size() <= max;
    }
    
    function isValidTimestamp(field) {
       return request.resource.data[field] is timestamp;
    }

    // Validators
    function isValidTextbook() {
      return hasRequiredFields(['name', 'url', 'createdAt']) &&
             isValidString('name', 1, 100) &&
             isValidString('url', 1, 500) &&
             isValidTimestamp('createdAt');
    }

    function isValidGroup() {
      return hasRequiredFields(['name', 'createdAt']) &&
             isValidString('name', 1, 50) &&
             isValidTimestamp('createdAt');
    }

    // Rules
    match /textbooks/{document} {
      allow read: if true;
      allow create: if isAdmin() && isValidTextbook();
      allow update: if isAdmin() && isValidTextbook();
      allow delete: if isAdmin();
    }

    match /textbook_groups/{document} {
      allow read: if true;
      allow create: if isAdmin() && isValidGroup();
      allow update: if isAdmin() && isValidGroup();
      allow delete: if isAdmin();
    }

    match /materials/{document} {
      allow read: if true;
      allow create: if isAdmin() && isValidTextbook();
      allow update: if isAdmin() && isValidTextbook();
      allow delete: if isAdmin();
    }

    match /material_groups/{document} {
      allow read: if true;
      allow create: if isAdmin() && isValidGroup();
      allow update: if isAdmin() && isValidGroup();
      allow delete: if isAdmin();
    }
  }
}
