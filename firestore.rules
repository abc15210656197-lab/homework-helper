rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: zhang_jingyang
    // Fields:
    //   - avatarUrls: list of strings (required) - List of avatar URLs
    //   - currentAvatarIndex: number (required) - Index of current avatar
    //   - updatedAt: timestamp (optional) - Last update time
    //   - updatedBy: string (optional) - User UID who updated
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "abc15210656197@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['avatarUrls', 'currentAvatarIndex']) &&
             data.avatarUrls is list &&
             data.currentAvatarIndex is number &&
             data.currentAvatarIndex >= 0 &&
             (data.avatarUrls.size() == 0 || data.currentAvatarIndex < data.avatarUrls.size());
    }

    match /settings/zhang_jingyang {
      allow read: if true; // Everyone can see the avatars
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /textbooks/{textbookId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /textbook_groups/{groupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /materials/{materialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /material_groups/{groupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if request.auth.uid == userId || isAdmin();
    }
  }
}
